# Copie este arquivo para .env (não versionado) e ajuste os valores para o seu ambiente local.
# O `docker compose` lê o `.env` automaticamente para resolver as variáveis usadas em compose.yaml.
#
# Os valores abaixo são só exemplos para desenvolvimento local — troque-os por algo próprio.
# compose.yaml exige (via ${VAR:?...}) que toda credencial de senha esteja definida; não há
# fallback para "guest"/"admin"/"secret" propositalmente (ver achado de security review em
# docs/DECISIONS.md, D004).

# Postgres — usado pela aplicação (banco "mydatabase")
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=changeme-postgres-local

# Banco dedicado do Keycloak no mesmo container Postgres (D004) — role própria, sem
# reaproveitar as credenciais acima.
KEYCLOAK_DB_USER=keycloak_app
KEYCLOAK_DB_PASSWORD=changeme-keycloak-db-local

# RabbitMQ (D002)
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=changeme-rabbitmq-local
# Porta fixa da management UI (uso humano, não usada pela aplicação)
RABBITMQ_MANAGEMENT_PORT=15672

# Keycloak — console de administração
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak-admin-local
# Porta fixa, exposta só em 127.0.0.1 (ver compose.yaml)
KEYCLOAK_HTTP_PORT=8081

# Observabilidade (specs/002-observabilidade.md) — atrás do profile "observability"
# (docker compose --profile observability up). Portas fixas, só em 127.0.0.1.
PROMETHEUS_PORT=9090
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-grafana-local

# Segurança (specs/003-seguranca-rbac-abac.md) — realm, papéis e usuários de teste do
# Keycloak vêm de docker/keycloak/import/gestao-realm.json (realm como código,
# importado automaticamente via `start-dev --import-realm`), não de variáveis de
# ambiente. Usuários de teste (senha = usuário + "123", ex: aluno.teste/aluno123):
# aluno.teste, secretaria.teste, admin.teste — dev-only, nunca dados reais.
#
# Exceção: o secret do client confidential "gestao-backend" (D013) é lido do ambiente
# via ${env.KEYCLOAK_BACKEND_CLIENT_SECRET} dentro do próprio realm export (achado de
# security review: evita o mesmo valor fixo em texto claro em todo clone do repo).
# Sem consumidor de código nesta fase.
KEYCLOAK_BACKEND_CLIENT_SECRET=changeme-keycloak-backend-secret-local

# Credencial dedicada (Basic Auth) para o Prometheus escrapar /actuator/prometheus
# (achado de security review - H1). Precisa bater com o valor hardcoded em
# docker/prometheus/prometheus.yml e em application.properties — a app roda no host,
# fora do compose (D003), então esta variável específica não é lida via .env pela
# própria app (mesma limitação já documentada para JAEGER_OTLP_HTTP_PORT); documentada
# aqui só para deixar claro que os três valores (aqui, prometheus.yml, application.properties)
# precisam ficar sincronizados manualmente se você trocá-los.
# PROMETHEUS_SCRAPE_PASSWORD=changeme-prometheus-scrape-local

# Origem do frontend Angular, liberada via CORS (D042). Mesma limitação de
# JAEGER_OTLP_HTTP_PORT/PROMETHEUS_SCRAPE_PASSWORD acima: a app roda no host (D003), então
# só é lida se você exportar a variável no seu shell antes de rodar ./mvnw spring-boot:run
# (não é lida automaticamente do .env pela app, só documentada aqui). Default já cobre o
# `ng serve` local (:4200) sem precisar definir nada.
# APP_FRONTEND_ORIGIN=http://localhost:4200
